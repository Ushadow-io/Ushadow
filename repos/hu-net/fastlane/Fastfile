require 'json'

# hu-net — Fastlane iOS deployment automation
#
# Configuration is read from build.json in the app root:
#   {
#     "scheme": "hu-net",
#     "app_identifier": "io.hu-net.app",
#     "extensions": { "io.hu-net.app.widget": "WidgetTarget" }
#   }
#
# Credentials are read from eas.json (submit.production.ios).

default_platform(:ios)

# ════════════════════════════════════════════════════════════════════════
# Configuration helpers
# ════════════════════════════════════════════════════════════════════════

def build_config
  @build_config ||= begin
    path = File.expand_path('../build.json', FastlaneCore::FastlaneFolder.path)
    unless File.exist?(path)
      UI.user_error!("build.json not found at #{path}. Create one with scheme, app_identifier, and extensions.")
    end
    JSON.parse(File.read(path))
  end
end

def eas_config
  @eas_config ||= begin
    path = File.expand_path('../eas.json', FastlaneCore::FastlaneFolder.path)
    File.exist?(path) ? JSON.parse(File.read(path)) : {}
  end
end

def app_scheme
  build_config['scheme']
end

def app_identifier
  build_config['app_identifier']
end

def app_extensions
  build_config['extensions'] || {}
end

def ios_workspace
  "./ios/#{app_scheme}.xcworkspace"
end

def ios_project
  "./ios/#{app_scheme}.xcodeproj"
end

def apple_team_id
  eas_config.dig('submit', 'production', 'ios', 'appleTeamId') || ENV['APPLE_TEAM_ID'] || ''
end

# ════════════════════════════════════════════════════════════════════════
# Lanes
# ════════════════════════════════════════════════════════════════════════

platform :ios do
  before_all do
    # No git state checks - allow deploys with uncommitted changes
  end

  # ── Beta: Build + TestFlight ─────────────────────────────────────────

  desc "Build and upload to TestFlight"
  desc "This is the fastest way to deploy — no EAS queues!"
  lane :beta do
    api_key = app_store_connect_api_key_from_env

    # Step 0: Generate iOS project
    UI.message("🔧 Running expo prebuild for production variant...")
    sh("cd .. && APP_VARIANT=production npx expo prebuild --platform ios --clean")
    UI.message("📦 Running pod install...")
    sh("cd ../ios && bundle exec pod install")

    # Step 1: Sync build number with App Store Connect
    UI.message("📦 Syncing build number with App Store Connect...")

    asc_build = app_store_build_number(
      app_identifier: app_identifier,
      live: false,
      api_key: api_key,
    ).to_i
    project_build = get_build_number(xcodeproj: ios_project).to_i
    latest_build = [asc_build, project_build].max
    next_build = latest_build + 1

    UI.message("ASC build: #{asc_build}, project build: #{project_build} → using #{next_build}")

    increment_build_number(
      build_number: next_build,
      xcodeproj: ios_project
    )

    version = get_version_number(xcodeproj: ios_project, target: app_scheme)
    build = get_build_number(xcodeproj: ios_project)
    UI.success("Building version #{version} (#{build})")

    # Step 2: Build
    UI.message("🔨 Building iOS app...")
    build_ios_app(skip_prebuild: true)

    # Step 3: Upload
    ipa_path = lane_context[SharedValues::IPA_OUTPUT_PATH]
    UI.message("IPA path: #{ipa_path}")
    ipa_build = sh("unzip -p '#{ipa_path}' 'Payload/#{app_scheme}.app/Info.plist' | plutil -extract CFBundleVersion raw -o - -").strip rescue "unknown"
    UI.message("Build number inside IPA: #{ipa_build}")

    UI.message("🚀 Uploading to TestFlight...")
    upload_to_testflight(
      api_key: api_key,
      ipa: ipa_path,
      skip_waiting_for_build_processing: true,
      distribute_external: false,
      notify_external_testers: false,
      changelog: "Build #{build} - Automated deployment via Fastlane"
    )

    UI.success("✅ Successfully uploaded to TestFlight!")
    UI.success("Version: #{version} (Build: #{build})")
    UI.message("📱 Build will appear in TestFlight in ~5-10 minutes")
  end

  # ── Build only ──────────────────────────────────────────────────────

  desc "Build iOS app only (no upload)"
  lane :build do
    UI.message("🔨 Building iOS app...")
    build_ios_app(
      skip_package_ipa: false,
      export_method: "app-store"
    )
    UI.success("✅ Build complete!")
    UI.message("IPA location: #{lane_context[SharedValues::IPA_OUTPUT_PATH]}")
  end

  # ── Submit existing IPA ─────────────────────────────────────────────

  desc "Submit existing build to TestFlight"
  lane :submit do |options|
    api_key = app_store_connect_api_key_from_env
    ipa_path = options[:ipa] ||
               lane_context[SharedValues::IPA_OUTPUT_PATH] ||
               File.expand_path("../build/#{app_scheme}.ipa", __dir__)

    unless File.exist?(ipa_path)
      UI.user_error!("No IPA file found at #{ipa_path}. Run 'make fastlane-beta' to build first.")
    end

    UI.message("Using IPA: #{ipa_path}")
    UI.message("🚀 Uploading to TestFlight...")
    upload_to_testflight(
      api_key: api_key,
      ipa: ipa_path,
      skip_waiting_for_build_processing: true,
      distribute_external: false,
      notify_external_testers: false
    )
    UI.success("✅ Successfully uploaded to TestFlight!")
  end

  # ── Bump build number ──────────────────────────────────────────────

  desc "Increment build number (synced with App Store Connect)"
  lane :bump_build do
    asc_build = app_store_build_number(
      app_identifier: app_identifier,
      live: false,
    ).to_i
    project_build = get_build_number(xcodeproj: ios_project).to_i
    latest_build = [asc_build, project_build].max
    next_build = latest_build + 1
    increment_build_number(build_number: next_build, xcodeproj: ios_project)
    version = get_version_number(xcodeproj: ios_project, target: app_scheme)
    build = get_build_number(xcodeproj: ios_project)
    UI.success("ASC: #{asc_build}, project: #{project_build} → New build: #{build} (version #{version})")
  end

  # ════════════════════════════════════════════════════════════════════
  # Private lanes
  # ════════════════════════════════════════════════════════════════════

  desc "Build the iOS app"
  private_lane :build_ios_app do |options|
    team_id = apple_team_id

    unless options[:skip_prebuild]
      UI.message("🔧 Running expo prebuild for production variant...")
      sh("cd .. && APP_VARIANT=production npx expo prebuild --platform ios --clean")
      UI.message("📦 Running pod install...")
      sh("cd ../ios && bundle exec pod install")
    end

    # Fetch provisioning profiles for main app + all extensions
    UI.message("📲 Fetching provisioning profiles...")
    api_key = app_store_connect_api_key_from_env

    provisioning_profiles = {}

    # Main app
    get_provisioning_profile(
      app_identifier: app_identifier,
      team_id: team_id,
      api_key: api_key,
    )
    main_uuid = ENV["sigh_#{app_identifier}_appstore_profile-uuid"]
    main_name = ENV["sigh_#{app_identifier}_appstore_profile-name"]
    UI.success("Main app profile: #{main_name} (#{main_uuid})")
    provisioning_profiles[app_identifier] = main_uuid

    # Extensions
    app_extensions.each do |ext_id, _ext_name|
      get_provisioning_profile(
        app_identifier: ext_id,
        team_id: team_id,
        api_key: api_key,
      )
      ext_uuid = ENV["sigh_#{ext_id}_appstore_profile-uuid"]
      ext_name_val = ENV["sigh_#{ext_id}_appstore_profile-name"]
      UI.success("Extension profile (#{ext_id}): #{ext_name_val} (#{ext_uuid})")
      provisioning_profiles[ext_id] = ext_uuid
    end

    gym(
      workspace: ios_workspace,
      scheme: app_scheme,
      export_method: "app-store",
      configuration: "Release",
      clean: true,
      output_directory: "./build",
      output_name: "#{app_scheme}.ipa",
      export_options: {
        method: "app-store",
        teamID: team_id,
        compileBitcode: false,
        provisioningProfiles: provisioning_profiles,
      },
      skip_package_ipa: options[:skip_package_ipa] || false,
    )
  end

  # App Store Connect API key from environment
  private_lane :app_store_connect_api_key_from_env do
    if ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"] &&
       ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"] &&
       ENV["APP_STORE_CONNECT_API_KEY_KEY_FILEPATH"]
      app_store_connect_api_key(
        key_id:        ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"].strip,
        issuer_id:     ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"].strip,
        key_filepath:  File.expand_path(ENV["APP_STORE_CONNECT_API_KEY_KEY_FILEPATH"].strip),
      )
    else
      nil  # Fall back to Apple ID / password auth
    end
  end

  # ════════════════════════════════════════════════════════════════════
  # Error handling
  # ════════════════════════════════════════════════════════════════════

  error do |lane, exception|
    UI.error("Error in lane '#{lane}':")
    UI.error(exception.message)
  end

  after_all do |lane|
    UI.success("Successfully completed '#{lane}' lane! 🎉")
  end
end
